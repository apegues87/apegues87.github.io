"Our engine makes quick work of file editing for PDFs.\\nJust upload or drop a PDF or other document to get started!\",\"file\":\"Drop your file here\",\"merge\":\"Merge your PDFs effortlessly with our software.\\nJust upload your files to get started!\",\"pdf\":\"Drop PDF files here\",\"rotate\":\"Quickly rotate your PDFs and other documents with ease.\\nSimply upload your file to begin!\",\"sign\":\"Simply upload your file to begin!\",\"split\":\"Our engine makes quick work of file editing for PDFs.\\nJust upload a PDF or other document to get started!\"},\"errors\":{\"1\":\"one\",\"10\":\"ten\",\"FILE_INVALID_TYPE\":\"Please upload the correct file type.\",\"FILE_TOO_LARGE\":\"The file size must not exceed {size} MB\",\"TOO_MANY_FILES\":\"{count, plural, one {Please upload one file at a time. For multiple PDF files, use the \u003clink\u003ePDF Merge tool\u003c/link\u003e.} other {You can upload up to {count} files at a time.}}\"},\"excellent\":\"Excellent\",\"external\":{\"dropbox\":\"Upload from Dropbox\",\"googleDrive\":\"Upload from Google Drive\",\"oneDrive\":\"Upload from OneDrive\"},\"imageAlt\":\"Drag and drop files\",\"invalidTypeModal\":{\"description\":\"Please upload one of the supported formats:\",\"done\":\"Done\",\"title\":\"Unsupported file type\"},\"or\":\"OR\",\"processing\":\"{percent}% processing\",\"title\":{\"convert\":\"Convert PDFs and More\",\"delete\":\"Remove PDF Pages in Seconds\",\"edit\":\"Edit your PDF Now\",\"merge\":\"Merge your PDFs now\",\"rotate\":\"Rotate Your PDF Instantly\",\"sign\":\"Sign your documents with ease.\",\"split\":\"Split your PDF now\",\"upload\":\"Upload your files\"},\"trustpilot\":{\"rating\":\"4.6\",\"starAlt\":\"Trustpilot star {starNumber}\",\"starFillAlt\":\"Trustpilot star\",\"title\":\"Trustpilot\"},\"uploadButtonActions\":{\"convert\":\"Upload to convert\",\"delete\":\"Upload to edit\",\"edit\":\"Upload to edit\",\"merge\":\"Upload to merge\",\"rotate\":\"Upload to rotate\",\"sign\":\"Upload to sign\",\"split\":\"Upload to split\"},\"uploading\":\"Uploading your file…\",\"uploadInProgress\":{\"continue\":\"Continue uploading\",\"description\":\"Leaving now will stop the upload. You’ll need to start over.\",\"leave\":\"Leave anyway\",\"title\":\"Upload in progress\"}}},\"ContactUs\":{\"description\":\"Got a question, feedback, or need assistance? \\nWe’d love to hear from you!\",\"form\":{\"title\":\"Get in touch\"},\"info\":{\"company\":{\"label\":\"Locations\",\"value\":\"Trevora EOOD\\nRing Tower, Lane “Okolovrasten pat” 251E,\\nFloor 3. 1766 Sofia, Bulgaria\",\"value_us\":\"Pdfhelp LLC\\n1151 Walker Rd Ste 100\\nDover, 19904\\nDelaware, US\"},\"email\":\"Email:\",\"phone\":\"Phone:\",\"title\":\"Contact Information\"},\"title\":\"We're Here to Help!\"},\"dashboard\":{\"add\":\"Add\",\"addNew\":\"Add new\",\"documents\":{\"empty\":{\"actionLabel\":\"Upload to edit\",\"imageAlt\":\"Drag and drop files\",\"or\":\"OR\",\"subtitle\":\"Drop PDF files here\",\"title\":\"Your workplace is ready to go!\"}},\"forms\":{\"table\":{\"label\":\"Name\"},\"types\":{\"cms1500\":\"CMS-1500\",\"ds11\":\"DS-11\",\"ds82\":\"DS-82\",\"fw4\":\"W-4\",\"fw9\":\"W-9\",\"i864\":\"I-864\",\"i9\":\"I-9\"}},\"search\":{\"formsPlaceholder\":\"Search forms\",\"mobilePlaceholder\":\"Search\",\"placeholder\":\"Search document\"},\"settings\":{\"billing\":{\"cancelSubscription\":\"Cancel Subscription\",\"membership\":\"Membership\",\"privacyPolicy\":\"Privacy Policy\",\"subscribe\":\"Subscribe\",\"subscription\":\"Subscription\",\"tab\":\"Billing\",\"termsConditions\":\"Terms \u0026 Conditions\"},\"deleteAccount\":{\"actionLabel\":\"Delete Account\",\"cancelLabel\":\"Close\",\"description\":\"Please note that upon confirming, you will immediately lose access to the member area.\",\"done\":\"Done\",\"label\":\"Delete Account\",\"success\":\"Your account was deleted successfully.\",\"title\":\"Are you sure you want to delete your account? \"},\"general\":{\"changePassword\":\"Change Password\",\"confirmNewPassword\":\"Repeat New Password\",\"currentPassword\":\"Current Password\",\"email\":\"Email address\",\"emailPlaceholder\":\"john.doe@example.com\",\"firstName\":\"First name\",\"fullName\":\"First and last name\",\"fullNamePlaceholder\":\"Enter your full name\",\"lastName\":\"Last name\",\"logout\":\"Log out\",\"newPassword\":\"New Password\",\"profileDetails\":\"Profile Details\",\"save\":\"Save Changes\",\"savePassword\":\"Save Password\",\"tab\":\"General\",\"title\":\"Settings\",\"toast\":{\"passwordSuccess\":{\"description\":\"Your password has been updated successfully.\",\"title\":\"Password updated\"},\"success\":{\"description\":\"Your profile has been updated successfully.\",\"title\":\"Profile updated\"}}},\"help\":{\"tab\":\"Contact Us\"}},\"sidebar\":{\"allDocuments\":\"All documents\",\"contactUs\":\"Contact Us\",\"documents\":\"Documents\",\"forms\":\"Forms\",\"myAccount\":\"Settings\",\"recentDocuments\":\"Recents\",\"tools\":\"Tools\"}},\"errors\":{\"CREDENTIALS_ERROR\":{\"description\":\"The email or password you entered is incorrect. Please try again.\",\"title\":\"Invalid credentials\"},\"USER_EXISTS_ERROR\":{\"description\":\"This email is already registered. Please log in or use a different email address.\",\"title\":\"User already exists\"},\"USER_GENERIC_ERROR\":{\"title\":\"Wrong email or password\"},\"USER_NOT_FOUND_ERROR\":{\"title\":\"User not found\"}},\"FacebookDataDeletionPage\":{\"buttonText\":\"Go Home\",\"failure\":{\"description\":\"We could not find a data deletion request associated with the provided confirmation code: \u003cstrong\u003e{confirmationCode}\u003c/strong\u003e Please make sure you’ve used the correct link from Facebook.\",\"title\":\"Unable to find deletion request!\"},\"success\":{\"description\":\"We have processed your request to delete your personal data from PDF Help. Thank you for using our service!\",\"title\":\"Your data has been successfully deleted!\"}},\"formFields\":{\"email\":{\"invalid\":\"Please enter a valid email address\",\"label\":\"Email Address\",\"placeholder\":\"Your email address\",\"required\":\"Email is required\"},\"invalid\":\"This field is invalid\",\"lettersOnly\":\"Only letters are allowed\",\"max\":\"This field cannot include more than {max} characters\",\"min\":\"This field cannot include less than {min} characters\",\"password\":{\"doesNotMatch\":\"Passwords do not match\",\"label\":\"Password\",\"required\":\"Password is required\",\"strong\":\"Password must be at least 8 characters long and contain at least one uppercase letter, one lowercase letter, and one special character\"},\"required\":\"This field is required\"},\"Forms\":{\"card\":{\"action\":\"View form\"},\"filling\":{\"1\":\"Click the \\\"Get {type} Form\\\" button at the top of the page\",\"2\":\"Make your edits\",\"3\":\"Once you're finished, click \\\"Done\\\" and select the format you prefer. Rename it if you’d like.\",\"subtitle\":\"Use the instructions below to start using our professional PDF editor for the {type} form:\",\"title\":\"How to fill out a {type} form?\"},\"hero\":{\"actionLabel\":\"Get {type} Form\",\"description\":\"Printable template {year}\",\"disclaimer\":\"This website is not affiliated with the IRS\",\"title\":\"Get {year} {type} Form\",\"w9\":{\"description\":\"Printable template 2025-2026\",\"title\":\"Get Latest W-9 Form\"}},\"otherForms\":\"Other forms\",\"title\":\"All forms\",\"types\":{\"cms1500\":{\"card\":\"{type}\",\"name\":\"CMS-1500\"},\"ds11\":{\"card\":\"{type}\",\"name\":\"DS-11\"},\"ds82\":{\"card\":\"{type}\",\"name\":\"DS-82\"},\"fw4\":{\"card\":\"{type}\",\"name\":\"W-4\"},\"fw9\":{\"card\":\"{type}\",\"faq\":{\"1\":{\"answer\":\"\u003cul\u003e\u003cli\u003eAnyone receiving income that may be subject to backup withholding.\u003c/li\u003e\u003cli\u003eFreelancers, contractors, and vendors getting paid over $600 from a single payer in a year.\u003c/li\u003e\u003c/ul\u003e\",\"question\":\"Who needs a W-9 form?\"},\"2\":{\"answer\":\"\u003cul\u003e\u003cli\u003eIf you’re not employed or working as an independent contractor in the U.S.\u003c/li\u003e\u003cli\u003eNon-residents performing work outside the U.S.\u003c/li\u003e\u003cli\u003eIt’s mainly for U.S. persons (citizens or residents) to provide their Taxpayer Identification Numbers (TIN).\u003c/li\u003e\u003c/ul\u003e\",\"question\":\"When is a W-9 not required?\"},\"3\":{\"answer\":\"Our platform has a blank template ready for you to fill out - no need to download it elsewhere. Start editing right away and save when you’re done.\",\"question\":\"How to get a blank W-9 form?\"},\"4\":{\"answer\":\"The W-9 form helps accurately report your tax information, such as: \\n\\n \u003cul\u003e\u003cli\u003eProviding your TIN to entities that pay you.\u003c/li\u003e\u003cli\u003eConfirming your tax status as a U.S. person.\u003c/li\u003e\u003cli\u003eDeclaring any exemptions from backup withholding if needed.\u003c/li\u003e\u003c/ul\u003e\",\"question\":\"Why do you need a W-9?\"},\"5\":{\"answer\":\"Whenever there’s a change in your personal or business details (like a new address, name change, or updated TIN), provide a new W-9 to ensure accurate tax documentation.\",\"question\":\"When should you update your W-9?\"}},\"filling\":{\"subtitle\":\"It’s easy to get started:\",\"title\":\"Complete your W-9 in just a few steps\"},\"name\":\"W-9\",\"stepByStep\":{\"base\":{\"1\":{\"badge\":\"Line 1\",\"text\":\"Enter your full name as it appears on your tax documents.\"},\"2\":{\"badge\":\"Line 2\",\"text\":\"If you have a business name that’s different from your personal name, enter it here.\"},\"3\":{\"badge\":\"Line 3\",\"text\":\"Select your federal tax classification (individual, corporation, LLC, etc.).\"},\"4\":{\"badge\":\"Line 4\",\"text\":\"If you’re exempt from backup withholding, enter the appropriate code.\"},\"5\":{\"badge\":\"Line 5\",\"text\":\"Provide your complete address.\"},\"6\":{\"badge\":\"Line 6\",\"text\":\"Include your city, state, and ZIP code.\"},\"7\":{\"badge\":\"Line 7\",\"text\":\" List any account numbers your employer might need (optional).\"}},\"personal\":{\"1\":{\"badge\":\"Part I\",\"text\":\"Enter your TIN - taxpayer Identification Number: SSN - Social Security Number for individuals, EIN - Employer Identification Number for businesses.\"},\"2\":{\"badge\":\"Part II\",\"text\":\"Review your information carefully, then sign and date to certify accuracy.\"},\"description\":\"In the second part of the form, you’ll need to provide your personal information for your employer’s tax reporting. Here’s how to complete this section:\",\"title\":\"Personal Details Section\"},\"title\":\"W-9 form instructions – step by step\"},\"whatIs\":{\"1\":{\"description\":\"The W-9 form is crucial for accurate tax documentation, as it serves these key purposes: \\n\\n \u003cul\u003e\u003cli\u003eProviding your Taxpayer Identification Number (TIN) to entities that pay you.\u003c/li\u003e\u003cli\u003eCertifying your tax status as a U.S. person.\u003c/li\u003e\u003cli\u003eDeclaring any exemption from backup withholding, if applicable.\u003c/li\u003e\u003c/ul\u003e\",\"title\":\"What is the W-9 form used for?\"},\"2\":{\"description\":\"In certain cases, completing a W-9 may not be advisable. For example, if an unexpected party requests a W-9, make sure the reason for the request is valid. Financial institutions, such as banks, may use the W-9 form to report dividends at year-end; however, if they already have your TIN, submitting a new W-9 form might be redundant.\",\"title\":\"When might filling out a W-9 not be necessary?\"},\"3\":{\"description\":\"It’s important to provide a new W-9 form to your employer or client whenever there’s a change in your personal or business information, such as a new address, new Social Security Number, or name change due to marriage or other reasons. Updating this information ensures that all tax documentation remains accurate.\",\"title\":\"When should you submit an updated W-9?\"}}},\"i864\":{\"card\":\"{type}\",\"name\":\"I-864\"},\"i9\":{\"card\":\"{type}\",\"name\":\"I-9\"}}},\"HomePage\":{\"about\":\"Go to the about page\",\"allInOne\":{\"cards\":{\"1\":{\"description\":\"With PDF Help, there’s no need to switch between apps. Convert, edit, sign, split, and protect your PDF files – all in one simple browser-based platform.\",\"title\":\"All your PDF tools in one place\"},\"2\":{\"description\":\"Your documents stay safe with us. We use secure connections and encryption to protect your data every step of the way. Your privacy is always a priority.\",\"title\":\"Privacy you can trust\"},\"3\":{\"description\":\"PDF Help works online on any device – desktop, laptop, tablet, or phone. Whether you're using Windows, macOS, iOS, or Android, you can access our tools instantly, anytime, anywhere.\",\"title\":\"No downloads, no hassle\"},\"4\":{\"description\":\"Just upload your file, choose what you want to do, and let PDF Help handle the rest. Our intuitive interface is designed to save you time and make document work effortless.\",\"title\":\"Easy to use, no tech skills required\"},\"5\":{\"description\":\"Need it done quickly? Most tasks take just a few seconds – with high-quality results you can count on. Get your PDFs ready in moments, not minutes.\",\"title\":\"Fast and reliable results\"},\"6\":{\"description\":\"Got a question or hit a snag? Our support team is here to assist. Friendly, fast, and always ready to help you get back on track.\",\"title\":\"Real help, when you need it\"}},\"subtitle\":\"Simplify your document workflow with fast, secure, and easy-to-use tools\",\"title\":\"PDF Help: Your All-in-One PDF Solution\"},\"compressPdf\":{\"featureSteps\":{\"1\":\"Upload your PDF file to the upload area.\",\"2\":\"Instantly compress your PDF online.\",\"3\":\"Download your smaller, high-quality PDF in seconds.\",\"title\":\"Compress PDF in 3 easy steps\"},\"hero\":{\"bullets\":{\"1\":\"Compress PDFs online in seconds\",\"2\":\"No installation needed\",\"3\":\"Simple \u0026 effective for everyone\"},\"mobileDescription\":\"Keep high quality while reducing file size\",\"subtitle\":\"Keep high quality while reducing file size\",\"title\":\"Compress PDF\",\"upload\":{\"text\":\"Drop your files here\",\"uploadButtonText\":\"Upload PDF to compress\"}},\"upload\":{\"cta\":\"Upload PDF to compress\",\"description\":\"Upload your file and get a smaller PDF in seconds.\",\"title\":\"Compress PDF now\"}},\"deletePage\":{\"featureSteps\":{\"1\":\"Upload your PDF file to the upload area.\",\"2\":\"Select pages you want to delete.\",\"3\":\"Once finished, download your updated PDF file to your device.\",\"subtitle\":\"Remove unwanted pages from your PDF in seconds\",\"title\":\"Delete pages from PDF file in just 3 simple steps\"},\"hero\":{\"bullets\":{\"1\":\"Rearrange or remove pages you don't need\",\"2\":\"Add, highlight and edit text\",\"3\":\"Add an electronic signature\"},\"description\":\"Easy, fast, and secure.\",\"mobileDescription\":\"Easily remove pages from your PDF files\",\"subtitle\":\"Easily remove pages from your PDF files\",\"title\":\"Delete pages from PDFs\",\"upload\":{\"text\":\"Drop your file here\",\"uploadButtonText\":\"Upload PDF to edit\"}},\"upload\":{\"cta\":\"Upload PDF to edit\",\"description\":\"Quickly delete pages from your PDF\",\"title\":\"Delete PDF pages in seconds\"}},\"editPdf\":{\"featureSteps\":{\"1\":\"Click the “Upload to edit” button or move your PDF to the “Drop PDF files here” area \",\"2\":\"Edit your document according to your needs\",\"3\":\"Click on the “Download” button to save your edited document\",\"subtitle\":\"Upload \u0026 edit your document online in seconds\",\"title\":\"Edit PDF in 3 easy steps\"},\"hero\":{\"bullets\":{\"1\":\"Add, highlight and edit text\",\"2\":\"Rearrange or remove pages you don’t need\",\"3\":\"Add an electronic signature\"},\"description\":\"Easy, fast, and secure.\",\"mobileDescription\":\"Edit, convert, sign and manage your PDFs online - easy, fast, and secure.\",\"subtitle\":\"Edit, convert, sign and manage your PDFs online.\",\"title\":\"PDF Editor Online\",\"upload\":{\"text\":\"Drop your file here\",\"uploadButtonText\":\"Upload PDF to edit\"}},\"upload\":{\"cta\":\"Upload to edit\",\"description\":\"Our engine makes quick work of file editing for PDFs. Just upload a PDF or other document to get started!\",\"description_line_1\":\"Our engine makes quick work of file editing for PDFs.\",\"description_line_2\":\"Just upload a PDF or other document to get started!\",\"title\":\"Edit your PDF Now\"}},\"excelToPdf\":{\"featureSteps\":{\"1\":\"Upload your Excel spreadsheet to the upload area.\",\"2\":\"Let PDF Help process and convert it into a PDF.\",\"3\":\"Once finished, download your converted file to your device.\",\"title\":\"Convert Excel spreadsheet to PDF in just 3 simple steps\"},\"hero\":{\"bullets\":{\"1\":\"Edit text quickly\",\"2\":\"Keep the same look and layout\",\"3\":\"Add an electronic signature\"},\"mobileDescription\":\"Easily turn your Excel file into a PDF\",\"subtitle\":\"Easily turn your Excel file into a PDF\",\"title\":\"Convert Excel to PDF in seconds\",\"upload\":{\"text\":\"Drop your file here\",\"uploadButtonText\":\"Upload to convert\"}},\"upload\":{\"cta\":\"Upload to convert\",\"description\":\"Start by uploading your document to our online PDF converter.\",\"title\":\"Convert Excel to PDF\"}},\"faq\":{\"1\":{\"answer\":\"Absolutely! Our interface is designed to be simple and user-friendly. Whether you're tech-savvy or a beginner, you’ll find it easy to add annotations, highlights, and more.\",\"question\":\"I'm new to PDF annotation — is this tool easy to use?\"},\"2\":{\"answer\":\"Yes, your PDF files are protected. Our servers use advanced end-to-end encryption to ensure your data remains private and secure.\",\"question\":\"Is my PDF secure while using this tool?\"},\"3\":{\"answer\":\"Unfortunately, encrypted or password protected PDFs can’t be directly annotated. You'll need to unlock the file or save its contents in a separate document before adding your annotations.\",\"question\":\"Can I annotate encrypted or password protected PDFs?\"},\"4\":{\"answer\":\"Yes, you can remove or adjust annotations before downloading your file. If you’ve already downloaded it with errors, no worries — just re-upload the document to our tool and correct the mistakes.\",\"question\":\"Can I undo or delete annotations if I make a mistake?\"},\"5\":{\"answer\":\"To modify or reposition an annotation, you’ll need a tool that supports both PDF editing and annotation. Our platform offers both, making it easy to update your file.\",\"question\":\"How do I edit or move an annotation once I've added it?\"},\"6\":{\"answer\":\"To remove unwanted annotations, upload your file to our PDF editor, select the annotation you wish to remove, and download the updated document.\",\"question\":\"How do I delete annotations from my PDF?\"},\"7\":{\"answer\":\"Don't worry! Simply upload the document again, and you’ll be able to fix or remove the incorrect annotations.\",\"question\":\"What if I accidentally save my file with errors?\"},\"8\":{\"answer\":\"Absolutely! Our tool allows you to highlight important text, and draw directly on your PDF.\",\"question\":\"Can I highlight text in my PDF?\"},\"9\":{\"answer\":\"There’s no limit to the number of pages you can annotate, but your file must be under 100 MB.\",\"question\":\"Is there a limit to how many pages I can annotate?\"},\"10\":{\"answer\":\"Yes! Our tool works with scanned PDFs, just like standard PDF files.\",\"question\":\"Can I annotate scanned PDF documents?\"},\"11\":{\"answer\":\"Yes! Our tool allows you to fill in interactive PDF forms.\",\"question\":\"Can I fill out forms using this tool?\"},\"12\":{\"answer\":\"Yes! Our online PDF editor is fully mobile-friendly, allowing you to annotate PDFs right from your phone.\",\"question\":\"Can I use this PDF editor on my smartphone?\"},\"13\":{\"answer\":\"No, you'll need to upload and annotate each PDF file individually.\",\"question\":\"Can I annotate multiple PDFs at once?\"},\"14\":{\"answer\":\"If your PDF is scanned or locked in image format, try using an OCR (Optical Character Recognition) tool first to convert the text into editable content.\",\"question\":\"What if my PDF has text that won’t let me highlight or annotate?\"},\"15\":{\"answer\":\"Unfortunately, once an annotation is deleted and the file is downloaded, it can’t be restored. We recommend saving multiple versions as backups.\",\"question\":\"I accidentally deleted an important annotation — can I recover it?\"},\"16\":{\"answer\":\"Yes, once you’ve finished editing your file, you can easily download and share it via email, cloud storage, or messaging apps.\",\"question\":\"Can I share my annotated PDF directly with others?\"},\"17\":{\"answer\":\"While you can’t collaborate live, you can share the PDF with others who can add their own annotations using the tool.\",\"question\":\"Does the tool support collaboration on PDFs?\"},\"editPdf\":{\"subtitle\":\"Everything you need to know about our tool\",\"title\":\"Frequently Asked Questions\"},\"fw9\":{\"subtitle\":\"Our answers are here to support you\",\"title\":\"Your questions are important\"},\"showAllButton\":\"Show all\",\"showLessButton\":\"Show less\",\"subtitle\":\"We’ve Got Answers\",\"title\":\"Got Questions?\"},\"footer\":{\"about\":\"About Us\",\"cancelSubscription\":\"Cancel Subscription\",\"caption\":\"© {year} Pdfhelp.com. All rights reserved.\",\"contactUs\":\"Contact Us\",\"faq\":\"FAQs\",\"formsLegal\":\"PDFHelp is an independent platform and is not affiliated with, endorsed by, or approved by any government agency (including IRS, SSA, or USCIS) or any other editors, brands, or organizations. PDFHelp is not a law firm, and its tools, forms, and templates do not constitute legal advice or replace an attorney. We do not guarantee that any forms or templates are accurate, complete, or up to date; users are responsible for verifying they are using the correct and current versions for their needs. For legal questions, please consult a qualified professional. PDFHelp does not sell blank government forms.\",\"pricing\":\"Pricing\",\"privacy\":\"Privacy Policy\",\"terms\":\"Terms of Use\"},\"hero\":{\"disclaimer\":\"Easy to use | Full privacy | 24/7 support\"},\"imageToPdf\":{\"featureSteps\":{\"1\":\"Upload your image to the upload area.\",\"2\":\"Let PDF Help process and convert it into a PDF.\",\"3\":\"Once finished, download your converted file to your device.\",\"title\":\"Convert image to PDF in just 3 simple steps\"},\"hero\":{\"bullets\":{\"1\":\"Edit text with OCR\",\"2\":\"Drawing and design features included\",\"3\":\"Add an electronic signature\"},\"mobileDescription\":\"Quickly turn any Image into a PDF\",\"subtitle\":\"Quickly turn any Image into a PDF\",\"title\":\"Convert Image to PDF in seconds\",\"upload\":{\"text\":\"Drop your file here\",\"uploadButtonText\":\"Upload image to convert\"}},\"upload\":{\"cta\":\"Upload image to convert\",\"description\":\"Start by uploading your image to our online PDF converter.\",\"title\":\"Convert Image to PDF\"}},\"instruction\":{\"convert\":{\"steps\":{\"1\":\"Upload your file: Click \\\"Upload to Convert\\\" or drag and drop your document into the \\\"Drop Here\\\" area\",\"2\":\"Modify your document as needed\",\"3\":\"Click \\\"Convert\\\" and choose your preferred format\",\"4\":\"Download: Save the newly converted file\"},\"subtitle\":\"Easily convert your document online in just a few steps:\",\"title\":\"How It Works\"},\"delete\":{\"steps\":{\"1\":\"Upload your PDF via the \\\"Upload to Edit\\\" button or drag it into the \\\"Drop Here\\\" area\",\"2\":\"Open the \\\"Settings\\\" from the top toolbar\",\"3\":\"Select pages and click \\\"Delete Pages\\\"\",\"4\":\"Save and click \\\"Download\\\" to get your updated file\"},\"subtitle\":\"\",\"title\":\"Delete PDF Pages: Quick Guide\"},\"edit\":{\"steps\":{\"1\":\"Click the \\\"Upload to edit\\\" button or move your PDF to the \\\"Drop PDF files here\\\" area\",\"2\":\"Edit your document according to your needs\",\"3\":\"Click on the \\\"Download\\\" button to download your edited document\"},\"subtitle\":\"Upload \u0026 change your document online within seconds:\",\"title\":\"How does it work?\"},\"instructionImageAlt\":\"Instruction\",\"merge\":{\"steps\":{\"1\":\"Click the \\\"Upload to merge\\\" button and choose the files you need to combine\",\"2\":\"Reorder, edit or delete unneeded pages\",\"3\":\"Click on the \\\"Download\\\" button and get your combined document\"},\"subtitle\":\"Upload \u0026 change your document online within seconds:\",\"title\":\"How does it work?\"},\"rotate\":{\"steps\":{\"1\":\"Upload your PDF via the \\\"Upload to Rotate\\\" button or drag it into the \\\"Drop Here\\\" area\",\"2\":\"Open the \\\"Settings\\\" from the top toolbar\",\"3\":\"Select pages and click \\\"Rotate Right\\\" or \\\"Rotate Left\\\"\",\"4\":\"Save and click \\\"Download\\\" to get your updated file\"},\"subtitle\":\" \",\"title\":\"Rotate PDF: Quick Guide\"},\"sign\":{\"steps\":{\"1\":\"Upload your document: Select your file and upload it securely to our server\",\"2\":\"Add your signature: Sign using your mouse, type your name, insert a signature image, or draw\",\"3\":\"Share for signing: Send the document or invite others to sign\"},\"subtitle\":\" \",\"title\":\"How It Works\"},\"split\":{\"steps\":{\"1\":\"Click the \\\"Upload to split\\\" button or move your PDF to the \\\"Move here\\\" area.\",\"2\":\"Select the \\\"Document editor\\\" tool located in the top toolbar of the editor page.\",\"3\":\"Select the pages you want to split, then click on the \\\"Extract Pages\\\" button located in the top menu of the tool.\"},\"subtitle\":\"Upload \u0026 split your PDFs easily\",\"title\":\"Split PDF: step-by-step guide\"}},\"jpgToPdf\":{\"featureSteps\":{\"1\":\"Upload your JPG file to the upload area.\",\"2\":\"Let PDF Help process and convert it into a PDF.\",\"3\":\"Once finished, download your converted file to your device.\",\"title\":\"Convert JPG to PDF in just 3 simple steps\"},\"hero\":{\"bullets\":{\"1\":\"Edit text with OCR\",\"2\":\"Drawing and design features included\",\"3\":\"Add an electronic signature\"},\"mobileDescription\":\"Quickly turn any JPG into a PDF\",\"subtitle\":\"Quickly turn any JPG into a PDF\",\"title\":\"Convert JPG to PDF in seconds\",\"upload\":{\"text\":\"Drop your file here\",\"uploadButtonText\":\"Upload to convert\"}},\"upload\":{\"cta\":\"Upload to convert\",\"description\":\"Start by uploading your document to our online PDF converter.\",\"title\":\"Convert JPG to PDF\"}},\"mergePdf\":{\"edit\":{\"addMore\":{\"label\":\"Add file\"},\"cardMenu\":{\"delete\":\"Delete\",\"duplicate\":\"Duplicate\",\"label\":\"More options\",\"moveDown\":\"Move down\",\"moveUp\":\"Move up\",\"reload\":\"Reload\"},\"deleteConfirm\":{\"cancel\":\"Cancel\",\"confirm\":\"Delete\",\"description\":\"This file will be removed from the merge list.\",\"title\":\"Delete file?\"},\"limits\":{\"description\":\"Max 10 documents · Max 100 MB total size\",\"dismiss\":\"Dismiss\",\"title\":\"Merging limits\"},\"merge\":\"Merge\",\"pages\":\"{count, plural, one {# page} other {# pages}}\",\"progress\":{\"combining\":\"Combining documents\",\"merging\":{\"title\":\"Merging your documents…\"},\"preparing\":\"Preparing final PDF\",\"scanning\":\"Scanning for viruses\"},\"sizeLimit\":{\"cancel\":\"Cancel\",\"description\":\"Your selection exceeds one or more allowed limits. Please reduce the number or size of documents and try again.\",\"reviewSelection\":\"Review selection\",\"table\":{\"allowed\":\"Allowed\",\"limitType\":\"Limit type\",\"numberOfDocuments\":\"Number of documents\",\"totalSize\":\"Total size\",\"yourSelection\":\"Your selection\"},\"title\":\"Merge size limit exceeded\"},\"uploading\":\"Upload